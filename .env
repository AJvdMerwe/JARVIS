# ──────────────────────────────────────────────────────────────────────────────
#  Virtual Personal Assistant – environment variables
#  Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Ollama ──────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b            # chat / reasoning model
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ─── vLLM  (OpenAI-compatible server) ────────────────────────────────────────
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2
VLLM_API_KEY=EMPTY                  # vLLM doesn't need a real key

# ─── Inference backend selector ──────────────────────────────────────────────
# Options: "ollama" | "vllm"
LLM_BACKEND=ollama

# ─── Whisper (voice) ─────────────────────────────────────────────────────────
WHISPER_MODEL=base                  # tiny | base | small | medium | large
VOICE_ENABLED=true
VOICE_LANGUAGE=en

# ─── Vector store ────────────────────────────────────────────────────────────
VECTOR_STORE_PATH=./data/vector_store
VECTOR_STORE_COLLECTION=assistant_docs

# Embedding backend: "huggingface" (in-process) | "ollama" (out-of-process)
#
# Use "ollama" if you hit CUDA out-of-memory errors during document ingestion.
# Ollama embeddings run inside the Ollama server process — zero application VRAM.
# Pull the model first:  ollama pull nomic-embed-text
#
EMBEDDING_BACKEND=ollama

# ── HuggingFace settings (used when EMBEDDING_BACKEND=huggingface) ──────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Device for the HuggingFace model: cpu (safe) | cuda | mps | auto
# Default "cpu" avoids competing with Docling layout models for VRAM.
# Set "cuda" only when you have sufficient headroom after Docling + LLM.
EMBEDDING_DEVICE=cpu

# ── Ollama embedding settings (used when EMBEDDING_BACKEND=ollama) ──────────
# Recommended low-VRAM models (pull with: ollama pull <model>):
#   nomic-embed-text          — 137M params, 768-dim, fast, great default
#   nomic-embed-text-v2-moe   — MoE, higher quality, same inference cost
#   mxbai-embed-large         — 335M params, 1024-dim, best quality
#   all-minilm                — 23M params, tiny footprint
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Texts embedded per batch — lower = less peak memory, higher = more throughput
EMBEDDING_BATCH_SIZE=32

CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ─── Document ingestion ──────────────────────────────────────────────────────
UPLOADS_PATH=./data/uploads

# ─── News  ───────────────────────────────────────────────────────────────────
NEWS_MAX_ARTICLES=10
# Comma-separated RSS feeds (defaults built-in, override here)
# NEWS_RSS_FEEDS=https://feeds.bbci.co.uk/news/rss.xml,...

# ─── Agent ───────────────────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=15
AGENT_VERBOSE=false
MEMORY_MAX_TOKENS=4096

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_PATH=./data/logs/assistant.log
