# ==============================================================================
#  Virtual Personal Assistant — .env
#  All settings with sensible defaults.
#  Edit values marked  ← CHANGE ME  then run:  bash start.sh
#
#  Quick-start checklist:
#    1. Set OLLAMA_MODEL to match your hardware (see table below)
#    2. Pull required models:
#         ollama pull llama3.1:8b          # chat model
#         ollama pull nomic-embed-text     # embedding model
#         ollama pull deepseek-r1:7b       # reasoning model (deep research)
#    3. Install Playwright browsers (for JS page fetching):
#         playwright install chromium
#    4. Run:  bash start.sh
# ==============================================================================


# ─── LLM Backend ──────────────────────────────────────────────────────────────
# "ollama"  — easy local inference, starts automatically via start.sh
# "vllm"    — OpenAI-compatible server, higher GPU throughput for multi-user use
LLM_BACKEND=ollama


# ─── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# Chat / reasoning model for all general agents.
# Recommended by available RAM / VRAM:
#   <= 4 GB   : llama3.2:3b  |  phi3:mini
#   <= 8 GB   : llama3.1:8b  |  mistral:7b          <- default
#   <= 16 GB  : llama3.1:70b-q4  |  qwen2.5:14b
#   GPU 24 GB : qwen2.5:72b-q4  |  llama3.3:70b
OLLAMA_MODEL=llama3.1:8b

# Reasoning model — used exclusively by DeepResearchAgent (plan -> gather ->
# evaluate -> synthesise). A thinking/reasoning model gives much better
# research quality than a general chat model.
#
# Pull before first use:  ollama pull deepseek-r1:7b
#
# Options (pull whichever fits your VRAM):
#   deepseek-r1:7b    — 7B,  fast,  strong reasoning           <- default
#   deepseek-r1:14b   — 14B, better quality, needs ~10 GB VRAM
#   qwen3:8b          — 8B,  competitive quality
#   qwen3:14b         — 14B, high quality
OLLAMA_REASONING_MODEL=deepseek-r1:7b


# ─── vLLM  (only needed when LLM_BACKEND=vllm) ────────────────────────────────
# Launch the server first:  bash scripts/start_vllm.sh
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2
VLLM_API_KEY=EMPTY


# ─── Embeddings ───────────────────────────────────────────────────────────────
# EMBEDDING_BACKEND controls where embeddings are computed:
#
#   "ollama"      — recommended for GPUs with limited VRAM
#                   Embeddings run inside the Ollama server process.
#                   Zero application-side VRAM — no competition with Docling.
#                   Eliminates the "pdfium library is destroyed" error during
#                   bulk document ingestion.
#
#   "huggingface" — in-process sentence-transformers model.
#                   Faster for CPU-only setups; may cause CUDA OOM on GPUs
#                   shared with Docling layout models.
#
EMBEDDING_BACKEND=ollama

# Ollama embedding model (EMBEDDING_BACKEND=ollama)
# Pull before first use:  ollama pull nomic-embed-text
#
# Model comparison:
#   nomic-embed-text          — 137 M params, 768-dim, fast          <- default
#   nomic-embed-text-v2-moe   — MoE, higher quality, same speed
#   mxbai-embed-large         — 335 M params, 1024-dim, best quality
#   all-minilm                — 23 M params, smallest and fastest
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# HuggingFace settings (EMBEDDING_BACKEND=huggingface only)
# Device: "cpu" is safe default; "cuda" only if you have VRAM headroom.
EMBEDDING_DEVICE=cpu
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Texts embedded per batch.  Lower = less peak memory, higher = more throughput.
# GPU VRAM guide:  < 6 GB -> 8   |  6-8 GB -> 16   |  8-16 GB -> 32   |  > 16 GB -> 64
EMBEDDING_BATCH_SIZE=32


# ─── Vector Store (ChromaDB) ──────────────────────────────────────────────────
VECTOR_STORE_PATH=./data/vector_store
VECTOR_STORE_COLLECTION=assistant_docs

# Chunk size controls granularity of document retrieval.
# Larger chunks give more context per result; smaller chunks are more precise.
#   Short docs / high precision : CHUNK_SIZE=256,  CHUNK_OVERLAP=32
#   General use (default)       : CHUNK_SIZE=512,  CHUNK_OVERLAP=64
#   Long-context models         : CHUNK_SIZE=1024, CHUNK_OVERLAP=128
CHUNK_SIZE=512
CHUNK_OVERLAP=64


# ─── Document Ingestion ───────────────────────────────────────────────────────
# Directory where uploaded files are stored before and after ingestion.
# Agent-generated files (save_text_file, save_code_file) go to a "generated/"
# sub-directory here automatically.
UPLOADS_PATH=./data/uploads


# ─── Voice ────────────────────────────────────────────────────────────────────
# Set VOICE_ENABLED=true to enable microphone input + text-to-speech output.
# System requirements:
#   Linux : sudo apt-get install ffmpeg portaudio19-dev
#   macOS : brew install ffmpeg portaudio
VOICE_ENABLED=false

# Whisper model size.  Larger = more accurate, slower to load on first use.
#   tiny   ->  39 MB   — very fast, lower accuracy
#   base   ->  74 MB   — good balance                   <- default
#   small  -> 244 MB   — better accuracy
#   medium -> 769 MB   — high accuracy
#   large  ->   1.5 GB — best accuracy, needs 4 GB+ VRAM
WHISPER_MODEL=base

# ISO 639-1 language code for Whisper transcription.
# "en" for English; use language-specific codes for other languages.
VOICE_LANGUAGE=en


# ─── Deep Research ────────────────────────────────────────────────────────────
# DeepResearchAgent: multi-turn gather -> evaluate -> synthesise pipeline.
# Uses OLLAMA_REASONING_MODEL for all three stages.

# Maximum gather->evaluate refinement cycles before moving to synthesis.
# Higher = more thorough but slower (each cycle adds approx 15-60 seconds).
RESEARCH_MAX_ITERATIONS=5

# Maximum evidence items (web search results + Wikipedia) to collect.
RESEARCH_MAX_SOURCES=8

# Character budget for evidence passed to the synthesis prompt.
# Increase for models with larger context windows (e.g. 12000 for 32k context).
RESEARCH_CHUNK_BUDGET=6000


# ─── Agent Behaviour ──────────────────────────────────────────────────────────
# Maximum ReAct loop iterations before the agent gives up and returns a partial answer.
AGENT_MAX_ITERATIONS=15

# Print every tool call, observation, and thought to stdout (useful for debugging).
AGENT_VERBOSE=false

# Conversation memory token budget.  Turns older than this threshold are
# automatically compressed by the ConversationSummariser.
MEMORY_MAX_TOKENS=4096


# ─── News ─────────────────────────────────────────────────────────────────────
NEWS_MAX_ARTICLES=10

# Optional: override the built-in RSS feed list (comma-separated URLs).
# Defaults include BBC, NYT, WSJ, TechCrunch, and Reuters.
# NEWS_RSS_FEEDS=https://feeds.bbci.co.uk/news/rss.xml,https://techcrunch.com/feed/


# ─── API Server ───────────────────────────────────────────────────────────────
# Used when running:  bash start.sh api
# Sliding-window rate limiter: max RATE_LIMIT_REQUESTS per RATE_LIMIT_WINDOW
# seconds per IP address.
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60


# ─── Logging ──────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_PATH=./data/logs/assistant.log