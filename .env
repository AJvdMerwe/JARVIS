# ==============================================================================
#  Virtual Personal Assistant — .env
#  All settings with sensible defaults. Edit the values marked ← CHANGE ME
#  then run:  bash start.sh
# ==============================================================================


# ─── LLM Backend ──────────────────────────────────────────────────────────────
# Choose "ollama" (local CPU-friendly) or "vllm" (GPU, higher throughput).
LLM_BACKEND=ollama


# ─── Ollama ───────────────────────────────────────────────────────────────────
# Server URL — default port is 11434.  start.sh starts Ollama automatically.
OLLAMA_BASE_URL=http://localhost:11434

# Chat model.  Recommended by hardware:
#   ≤ 4 GB RAM/VRAM : llama3.2:3b  or  phi3:mini
#   ≤ 8 GB          : llama3.1:8b  or  mistral:7b          ← default
#   ≤ 16 GB         : llama3.1:70b-q4  or  qwen2.5:14b
OLLAMA_MODEL=llama3.1:8b

# Reasoning model — used by DeepResearchAgent for plan / evaluate / synthesise.
# Pull before first use:  ollama pull deepseek-r1:7b
# Options: deepseek-r1:7b | deepseek-r1:14b | qwen3:8b | qwen3:14b
OLLAMA_REASONING_MODEL=deepseek-r1:7b

# Embedding model — see the Embeddings section below for full configuration.
OLLAMA_EMBEDDING_MODEL=nomic-embed-text


# ─── vLLM  (only needed when LLM_BACKEND=vllm) ────────────────────────────────
# Start the server first:  bash scripts/start_vllm.sh
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2
VLLM_API_KEY=EMPTY


# ─── Voice ────────────────────────────────────────────────────────────────────
# Set VOICE_ENABLED=true to use microphone input + text-to-speech output.
# Requires:  ffmpeg  +  portaudio19-dev  (Linux)  or  portaudio (macOS).
VOICE_ENABLED=false

# Whisper model size.  Larger = more accurate but slower to load.
#   tiny → 39 MB  |  base → 74 MB  |  small → 244 MB
#   medium → 769 MB  |  large → 1.5 GB
WHISPER_MODEL=base

# Language code for Whisper transcription (ISO 639-1, e.g. en, fr, de, es).
VOICE_LANGUAGE=en


# ─── Embeddings ───────────────────────────────────────────────────────────────
# Embedding backend: "ollama" (zero VRAM, runs in Ollama process — recommended)
#                    "huggingface" (in-process, may compete for VRAM with Docling)
EMBEDDING_BACKEND=ollama

# Ollama embedding model.  Pull before first use:
#   ollama pull nomic-embed-text
#
# Recommended models:
#   nomic-embed-text          — 137 M params, 768-dim, fast, great default
#   nomic-embed-text-v2-moe   — MoE architecture, higher quality, same speed
#   mxbai-embed-large         — 335 M params, 1024-dim, highest quality
#   all-minilm                — 23 M params, smallest and fastest
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Device for HuggingFace embeddings (only used when EMBEDDING_BACKEND=huggingface).
# "cpu" is safe; use "cuda" only if you have VRAM headroom after Docling + LLM.
EMBEDDING_DEVICE=cpu

# HuggingFace model name (only used when EMBEDDING_BACKEND=huggingface).
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Texts embedded per batch — lower = less peak memory, higher = more throughput.
# Recommended: 8–16 for 6 GB GPU, 32 for 8 GB+, 64+ for 16 GB+.
EMBEDDING_BATCH_SIZE=32


# ─── Vector Store (ChromaDB) ──────────────────────────────────────────────────
VECTOR_STORE_PATH=./data/vector_store
VECTOR_STORE_COLLECTION=assistant_docs

# Document chunking — increase CHUNK_SIZE for longer context models.
CHUNK_SIZE=512
CHUNK_OVERLAP=64


# ─── Document Ingestion ───────────────────────────────────────────────────────
# Where uploaded documents are saved before ingestion.
UPLOADS_PATH=./data/uploads


# ─── News ─────────────────────────────────────────────────────────────────────
NEWS_MAX_ARTICLES=10

# Optional: override default RSS feeds (comma-separated URLs).
# Defaults include BBC, NYT, WSJ, TechCrunch.
# NEWS_RSS_FEEDS=https://feeds.bbci.co.uk/news/rss.xml,https://techcrunch.com/feed/


# ─── Agent Behaviour ──────────────────────────────────────────────────────────
# Maximum ReAct loop iterations before giving up.
AGENT_MAX_ITERATIONS=15

# Set AGENT_VERBOSE=true to print every tool call and thought to stdout.
AGENT_VERBOSE=false

# Conversation memory token budget (older turns are summarised above this).
MEMORY_MAX_TOKENS=4096


# ─── Deep Research ────────────────────────────────────────────────────────────
# Controls the DeepResearchAgent gather→evaluate loop.
# Max gather→evaluate cycles before the agent moves on to synthesis.
RESEARCH_MAX_ITERATIONS=5

# Maximum evidence items (web search results + Wikipedia) to collect.
RESEARCH_MAX_SOURCES=8

# Character budget for evidence passed to the synthesis prompt.
# Increase if using a model with a larger context window.
RESEARCH_CHUNK_BUDGET=6000


# ─── API Server ───────────────────────────────────────────────────────────────
# Used when running:  bash start.sh api
# Rate limiting — requests per window per IP address.
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60


# ─── Logging ──────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_PATH=./data/logs/assistant.log